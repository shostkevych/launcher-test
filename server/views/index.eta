<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Todo App</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0a0e27;
      color: #e2e8f0;
      padding: 2rem;
      min-height: 100vh;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
    }
    h1 {
      text-align: center;
      margin-bottom: 2rem;
      color: #818cf8;
    }
    .form {
      margin-bottom: 2rem;
    }
    .form input {
      width: 100%;
      padding: 0.75rem;
      font-size: 1rem;
      background: #1a1f3a;
      border: 1px solid #6366f1;
      border-radius: 8px;
      color: #e2e8f0;
    }
    .form input:focus {
      outline: none;
      border-color: #818cf8;
    }
    .form button {
      width: 100%;
      margin-top: 0.5rem;
      padding: 0.75rem;
      font-size: 1rem;
      background: #6366f1;
      color: white;
      border: none;
      border-radius: 8px;
      cursor: pointer;
    }
    .form button:hover {
      background: #818cf8;
    }
    .todo-list {
      list-style: none;
    }
    .todo-item {
      background: #1a1f3a;
      border: 1px solid rgba(99, 102, 241, 0.2);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 0.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .todo-item.completed {
      opacity: 0.6;
    }
    .todo-item.completed .todo-text {
      text-decoration: line-through;
    }
    .todo-text {
      flex: 1;
    }
    .todo-actions {
      display: flex;
      gap: 0.5rem;
    }
    .btn {
      padding: 0.5rem 1rem;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.875rem;
    }
    .btn-toggle {
      background: #6366f1;
      color: white;
    }
    .btn-toggle:hover {
      background: #818cf8;
    }
    .btn-delete {
      background: #ef4444;
      color: white;
    }
    .btn-delete:hover {
      background: #f87171;
    }
    .empty {
      text-align: center;
      color: #94a3b8;
      padding: 2rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Todo App</h1>
    
    <form method="POST" action="/todos" class="form">
      <input type="text" name="text" placeholder="Add a new todo..." required>
      <button type="submit">Add Todo</button>
    </form>
    
    <ul class="todo-list">
      ~ if (it.todos && it.todos.length > 0) { ~
        ~ it.todos.forEach(function(todo) { ~
          <li class="todo-item ~= todo.completed ? 'completed' : '' ~">
            <span class="todo-text">~= todo.text ~</span>
            <div class="todo-actions">
              <form method="POST" action="/todos/~= todo.id ~/toggle" style="display: inline;">
                <button type="submit" class="btn btn-toggle">
                  ~= todo.completed ? 'Undo' : 'Done' ~
                </button>
              </form>
              <form method="POST" action="/todos/~= todo.id ~/delete" style="display: inline;">
                <button type="submit" class="btn btn-delete">Delete</button>
              </form>
            </div>
          </li>
        ~ }); ~
      ~ } else { ~
        <li class="empty">No todos yet. Add one above!</li>
      ~ } ~
    </ul>
  </div>
</body>
</html>
