<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Todo App</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0a0a0a;
      color: #e5e5e5;
      min-height: 100vh;
      padding: 3rem 1.5rem;
    }
    .container {
      max-width: 500px;
      margin: 0 auto;
    }
    h1 {
      text-align: center;
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: #ffffff;
    }
    .subtitle {
      text-align: center;
      color: #737373;
      margin-bottom: 2.5rem;
      font-size: 0.95rem;
    }
    .form {
      display: flex;
      gap: 0.75rem;
      margin-bottom: 2rem;
    }
    .form input {
      flex: 1;
      padding: 1rem 1.25rem;
      font-size: 1rem;
      background: #171717;
      border: 1px solid #404040;
      border-radius: 12px;
      color: #e5e5e5;
      transition: all 0.2s;
    }
    .form input::placeholder {
      color: #737373;
    }
    .form input:focus {
      outline: none;
      border-color: #a3a3a3;
      box-shadow: 0 0 0 3px rgba(163, 163, 163, 0.15);
    }
    .form button {
      padding: 1rem 1.5rem;
      font-size: 1rem;
      font-weight: 600;
      background: #ffffff;
      color: #0a0a0a;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .form button:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(255, 255, 255, 0.15);
    }
    .todo-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .todo-item {
      background: #171717;
      border: 1px solid #262626;
      border-radius: 12px;
      padding: 1rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      transition: all 0.2s;
    }
    .todo-item:hover {
      border-color: #404040;
      transform: translateX(4px);
    }
    .todo-item.completed {
      opacity: 0.5;
    }
    .todo-item.completed .todo-text {
      text-decoration: line-through;
      color: #737373;
    }
    .todo-text {
      flex: 1;
      font-size: 1rem;
      word-break: break-word;
    }
    .todo-actions {
      display: flex;
      gap: 0.5rem;
    }
    .btn {
      padding: 0.5rem 0.875rem;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.8rem;
      font-weight: 500;
      transition: all 0.2s;
    }
    .btn-toggle {
      background: #262626;
      color: #d4d4d4;
      border: 1px solid #404040;
    }
    .btn-toggle:hover {
      background: #404040;
    }
    .btn-delete {
      background: #262626;
      color: #a3a3a3;
      border: 1px solid #404040;
    }
    .btn-delete:hover {
      background: #404040;
      color: #e5e5e5;
    }
    .empty {
      text-align: center;
      color: #737373;
      padding: 3rem 2rem;
      background: #171717;
      border-radius: 12px;
      border: 1px dashed #404040;
    }
    .empty-icon {
      font-size: 2.5rem;
      margin-bottom: 0.75rem;
      filter: grayscale(1);
    }
    .count {
      text-align: center;
      color: #737373;
      font-size: 0.85rem;
      margin-top: 1.5rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Todo App</h1>
    <p class="subtitle">Stay organized, get things done</p>
    
    <form method="POST" action="/todos" class="form">
      <input type="text" name="text" placeholder="What needs to be done?" required>
      <button type="submit">Add</button>
    </form>
    
    <ul class="todo-list">
      <% if (it.todos && it.todos.length > 0) { %>
        <% it.todos.forEach(function(todo) { %>
          <li class="todo-item <%= todo.completed ? 'completed' : '' %>">
            <span class="todo-text"><%= todo.text %></span>
            <div class="todo-actions">
              <form method="POST" action="/todos/<%= todo.id %>/toggle" style="display: inline;">
                <button type="submit" class="btn btn-toggle">
                  <%= todo.completed ? 'Undo' : 'Done' %>
                </button>
              </form>
              <form method="POST" action="/todos/<%= todo.id %>/delete" style="display: inline;">
                <button type="submit" class="btn btn-delete">Delete</button>
              </form>
            </div>
          </li>
        <% }); %>
      <% } else { %>
        <li class="empty">
          <div class="empty-icon">📝</div>
          No todos yet. Add one above!
        </li>
      <% } %>
    </ul>
    
    <% if (it.todos && it.todos.length > 0) { %>
      <p class="count">
        <%= it.todos.filter(t => !t.completed).length %> remaining · <%= it.todos.filter(t => t.completed).length %> completed
      </p>
    <% } %>
  </div>
</body>
</html>
